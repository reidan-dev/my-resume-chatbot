# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama              # "ollama" | "openai" | "claude"
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=                  # sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Embeddings ────────────────────────────────────────────────────────
EMBED_PROVIDER=ollama            # "ollama" | "openai"
EMBED_MODEL=nomic-embed-text
OPENAI_API_KEY=                  # used for LLM (if LLM_PROVIDER=openai) and/or embeddings

# ── Vector DB ─────────────────────────────────────────────────────────
VECTOR_DB=chroma                 # "chroma" | "pgvector" | "pinecone"
CHROMA_HOST=localhost
CHROMA_PORT=8001
PINECONE_API_KEY=
PINECONE_INDEX=resume
# Supabase pgvector — use postgresql+psycopg:// prefix (not postgresql://)
DATABASE_URL=

# ── Rate limiting & security ───────────────────────────────────────────
RATE_LIMIT_QUESTIONS=5           # Layer 2: max questions per IP per window
RATE_LIMIT_WINDOW_DAYS=3
BURST_LIMIT=3                    # Layer 2: max questions per IP per minute
GLOBAL_DAILY_LIMIT=100           # Layer 3: max total questions per day (all users)
MAX_MESSAGE_LENGTH=300            # Layer 1: max characters per message
LLM_MAX_TOKENS=500               # max tokens in LLM response
REDIS_URL=                       # leave empty → in-memory (dev only)

# ── SMTP (contact form) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # your Gmail address
SMTP_PASSWORD=                   # Gmail App Password (not your login password)
                                 # Enable at: myaccount.google.com/apppasswords
                                 # Requires 2FA on your Google account

# ── Bot ────────────────────────────────────────────────────────────────
BOT_NAME=Specs                   # displayed in system prompt and used by the LLM

# ── Contact info ───────────────────────────────────────────────────────
CONTACT_NAME=Reiniel Dan Pablo
CONTACT_EMAIL=reinieldan@gmail.com
CONTACT_LINKEDIN=https://www.linkedin.com/in/reiniel-dan-pablo
CONTACT_GITHUB=https://github.com/reidan-dev

# ── App ────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173
SESSION_MEMORY_TURNS=6
RETRIEVAL_TOP_K=4
